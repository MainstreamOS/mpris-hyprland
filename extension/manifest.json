{
  "manifest_version": 2,
  "name": "MPRIS for Hyprland",
  "short_name": "firefox-mpris-hyprland",
  "version": "0.1.0",
  "description": "Per-tab MPRIS bridge for Firefox — exposes Media Session metadata, position, and YouTube thumbnails on D-Bus for waybar / quickshell / playerctl.",
  "author": "MainstreamOS",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-mpris-hyprland@MainstreamOS",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "tabs",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false,
      "match_about_blank": false
    }
  ],
  "web_accessible_resources": ["inject.js"],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
