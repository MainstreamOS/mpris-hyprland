{
  "manifest_version": 3,
  "name": "MPRIS for Hyprland",
  "short_name": "firefox-mpris-hyprland",
  "version": "0.2.0",
  "description": "Per-tab MPRIS bridge for Firefox — exposes Media Session metadata, position, and artwork on D-Bus for waybar / quickshell / playerctl. Desktop-agnostic, lighter than plasma-browser-integration.",
  "author": "MainstreamOS",
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-mpris-hyprland@MainstreamOS",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
