{
  "manifest_version": 3,
  "name": "MPRIS for Hyprland",
  "short_name": "firefox-mpris-hyprland",
  "version": "0.2.0",
  "description": "Per-window MPRIS bridge for Chromium — exposes Media Session metadata, position, artwork, and per-tab volume on D-Bus for waybar / quickshell / playerctl. Desktop-agnostic, lighter than plasma-browser-integration.",
  "author": "MainstreamOS",
  "key": "",
  "permissions": [
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN",
      "match_about_blank": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": false
    }
  ],
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
