/host/target
*.xpi
# …except the maintainer-signed release the package ships (scripts/sign.sh).
!dist/mpris-hyprland.xpi
mpris-hyprland-host.json
build/
web-ext-artifacts/

# makepkg in-tree build artifacts (when running makepkg from the repo root)
pkg/
src/
/mpris-hyprland/
*.pkg.tar.zst
*.pkg.tar.zst.sig
/metadata

# web-ext sign local state (AMO add-on UUID)
extension/.amo-upload-uuid

# Chromium CRX signing — the private key NEVER ships (its public half is baked
# into manifest.chromium.json "key"; losing this key changes the extension ID).
chromium-signing-key.pem
.crx-pubkey.txt
.crx-extid.txt
*.crx
# …except the maintainer-signed release the package ships (mirrors the .xpi).
!dist/mpris-hyprland.crx
